---
import Base from "../../layouts/Base.astro";
import { books, type Book } from "../../data/books";

export function getStaticPaths() {
  return books.map((book) => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

interface Props {
  book: Book;
}

const { book } = Astro.props;
const stars = "\u2605".repeat(book.rating) + "\u2606".repeat(5 - book.rating);
---

<Base
  title={`${book.title} — Samuel Thien`}
  description={`${book.title} by ${book.author}`}
  ogImage={`/og/bookshelf/${book.slug}.png`}
  canonicalPath={`/bookshelf/${book.slug}`}
>
  <section class="pt-10 sm:pt-16 pb-20">
    <a
      href="/bookshelf"
      class="inline-flex items-center gap-2 font-ui text-sm text-ink-muted mb-10 sm:mb-14 transition-colors duration-250 hover:text-accent"
    >
      <span aria-hidden="true">&larr;</span> Bookshelf
    </a>

    <div class="book-note-hero">
      <div class="grid grid-cols-1 sm:grid-cols-[180px_1fr] lg:grid-cols-[220px_1fr] gap-8 sm:gap-10 lg:gap-14">
        {book.cover && (
          <div
            class="book-note-cover mx-auto sm:mx-0 w-[140px] sm:w-full"
            transition:name={`book-${book.slug}`}
          >
            <img
              src={book.cover}
              alt={`Cover of ${book.title}`}
              class="w-full rounded-lg border border-rule shadow-[0_4px_20px_oklch(0%_0_0_/_0.08)]"
            />
          </div>
        )}

        <div class="flex flex-col justify-center">
          <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold tracking-[-0.01em] leading-[0.95] mb-4 sm:mb-5">
            {book.title}
          </h1>
          <div class="font-ui text-sm text-ink-muted mb-3">
            {book.author} &middot; Read in {book.year}
          </div>
          <div class="text-accent text-xl sm:text-2xl tracking-wide select-none" aria-label={`Rated ${book.rating} out of 5`}>
            {stars}
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-rule mt-10 sm:mt-12 pt-8 sm:pt-10">
      <div class="font-ui text-xs text-ink-muted uppercase tracking-[0.06em] mb-6 sm:mb-8">
        Notes
      </div>
      <div class="max-w-2xl">
        <p class="text-lg sm:text-xl italic text-ink-soft leading-relaxed">
          {book.note}
        </p>
      </div>
    </div>
  </section>
</Base>

---
import Base from "../../layouts/Base.astro";
import BookshelfSection from "../../components/BookshelfSection.astro";
import { books } from "../../data/books";

const generalBooks = books.filter((b) => b.category === "general");
const technicalBooks = books.filter((b) => b.category === "technical");
---

<Base
  title="Bookshelf — Samuel Thien"
  description="Books that shaped how I think about software and systems."
  ogImage="/og/bookshelf.png"
  canonicalPath="/bookshelf"
>
  <section class="pt-12 sm:pt-20 pb-0">
    <div class="mb-12 sm:mb-16 reveal">
      <h1
        class="font-display text-4xl sm:text-6xl lg:text-7xl font-bold tracking-[-0.02em] leading-[0.95] mb-4"
      >
        Bookshelf
      </h1>
      <p
        class="text-lg sm:text-xl text-ink-soft max-w-md leading-relaxed"
      >
        Books I keep coming back to, or can't stop recommending.
      </p>
    </div>

    <BookshelfSection num="01" title="General Reading" books={generalBooks} />
    <BookshelfSection num="02" title="Technical Reading" books={technicalBooks} />
  </section>
</Base>

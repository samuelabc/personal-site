---
import SectionHeader from "./SectionHeader.astro";

const skills = [
  "Golang",
  "TypeScript",
  "React",
  "React Native",
  "Node.js",
  "Docker",
  "Kubernetes",
  "PostgreSQL",
  "Redis",
  "AWS",
  "Kafka",
  "Flutter",
];
---

<section class="py-16 sm:py-20 border-b border-rule reveal" id="about" data-reveal="slide-left">
  <SectionHeader num="01" title="About" />

  <div class="grid grid-cols-1 sm:grid-cols-[260px_1fr] gap-8 sm:gap-12 items-start">
    <div class="aspect-square rounded-xl overflow-hidden max-w-[260px] shadow-[0_4px_20px_oklch(0%_0_0_/_0.06)]">
      <img
        src="/samuel-thien-photo.png"
        alt="Samuel Thien"
        loading="lazy"
        class="block w-full h-full object-cover object-center scale-[1.08]"
      />
    </div>

    <div>
      <h3 class="font-display text-2xl sm:text-3xl font-bold italic mb-4 leading-tight text-ink">
        The short version
      </h3>
      <p class="text-[15px] sm:text-base leading-[1.75] text-ink-soft mb-4">
        Full stack engineer in Kuala Lumpur, 4+ years into building web and
        mobile platforms. I work mostly in Golang, Node.js, and React. I'm
        comfortable writing backend services and just as happy getting the
        frontend details right. Currently on the Cloud Security team at
        Mercedes-Benz.
      </p>
      <p class="text-[15px] sm:text-base leading-[1.75] text-ink-soft">
        Studied Computer Science at Beihang University in Beijing, graduated
        with honors, and published research on adversarial machine learning.
        I speak English, Chinese, and Malay.
      </p>

      <div class="flex flex-wrap gap-2 mt-6">
        {
          skills.map((skill) => (
            <span class="font-ui text-xs px-3 py-1 rounded-full bg-accent/[0.07] text-accent">
              {skill}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>

---
import SectionHeader from "./SectionHeader.astro";

const skills = [
  "Golang",
  "TypeScript",
  "React",
  "React Native",
  "Node.js",
  "Docker",
  "Kubernetes",
  "PostgreSQL",
  "Redis",
  "AWS",
  "Terraform",
  "Flutter",
];
---

<section class="py-16 border-b-3 border-ink reveal" id="about">
  <SectionHeader num="01" title="About" />

  <div class="grid grid-cols-[280px_1fr] gap-12 items-start">
    <div class="aspect-square border-3 border-ink relative overflow-hidden">
      <img
        src="/samuel-thien-photo.png"
        alt="Samuel Thien"
        class="absolute inset-0 block w-full h-full object-cover object-center scale-[1.08]"
      />
      <span
        class="absolute bottom-[-1px] right-[-1px] bg-accent text-white font-mono text-[10px] px-2.5 py-1.5 uppercase tracking-[0.1em] z-10"
        >That's me →</span
      >
    </div>

    <div>
      <h3 class="font-serif text-4xl font-normal italic mb-4 leading-tight">
        The short version —
      </h3>
      <p class="text-[15px] leading-[1.75] text-ink-soft mb-4">
        Full stack engineer based in Kuala Lumpur with 4+ years of experience
        building web and mobile platforms. I specialize in Golang, Node.js, and
        React — from high-performance microservices to polished frontends. Currently
        on the Cloud Security team at Mercedes-Benz.
      </p>
      <p class="text-[15px] leading-[1.75] text-ink-soft">
        I studied Computer Science at Beihang University in Beijing, where I
        graduated with honors and published research on adversarial machine learning.
        I speak English, Chinese, and Malay.
      </p>

      <div class="flex flex-wrap gap-1.5 mt-5">
        {
          skills.map((skill) => (
            <span class="font-mono text-[10px] uppercase tracking-[0.08em] px-2.5 py-1 border border-[#ccc5b8] text-ink-muted transition-all duration-200 ease-smooth hover:border-accent hover:text-accent">
              {skill}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>

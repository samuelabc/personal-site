<section class="border-b border-rule pt-16 sm:pt-24 pb-16 sm:pb-20 relative">
  <p
    class="hero-stagger hero-stagger-1 font-ui text-sm text-ink-muted mb-6"
  >
    Hey, I'm Samuel Thien
  </p>

  <h1
    class="font-display text-[clamp(2.25rem,6.5vw,4.5rem)] leading-[1.08] tracking-[-0.02em] font-bold mb-8"
  >
    <span class="hero-stagger hero-stagger-2 block">I build things</span>
    <span class="hero-stagger hero-stagger-3 block text-accent">with care.</span>
  </h1>

  <div class="hero-stagger hero-stagger-4 max-w-xl">
    <p class="text-base sm:text-[17px] leading-relaxed text-ink-soft">
      Full stack engineer in Kuala Lumpur. I work on backend systems and
      the frontends people actually use, mostly with Go, TypeScript, and React.
      Currently on the Cloud Security team at Mercedes-Benz.
    </p>
  </div>

  <div class="hero-stagger hero-stagger-5 mt-10 flex flex-wrap items-center gap-4">
    <a
      href="#projects"
      class="pressable group inline-flex items-center gap-2.5 px-7 py-3.5 bg-accent text-white font-ui text-sm tracking-wide rounded-lg transition-[background-color,transform,box-shadow] duration-300 ease-smooth hover:shadow-[0_6px_20px_oklch(48%_0.10_150_/_0.25)] hover:-translate-y-0.5 no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
    >
      See my work
      <span
        class="transition-transform duration-300 ease-smooth group-hover:translate-x-1"
        >&rarr;</span
      >
    </a>
    <a
      href="/samuel-thien-resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      data-track-event="resume-download"
      class="pressable group inline-flex items-center gap-2 px-7 py-3.5 border border-accent/40 text-accent font-ui text-sm tracking-wide rounded-lg transition-[background-color,color,border-color,transform,box-shadow] duration-300 ease-smooth hover:bg-accent/[0.06] hover:border-accent/50 hover:-translate-y-0.5 no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
    >
      Resume
      <svg class="w-3.5 h-3.5 transition-transform duration-300 ease-smooth group-hover:translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-6-6 6 6 6-6" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 19h16" />
      </svg>
    </a>
  </div>
</section>

<script>
  import { POSTHOG_EVENTS, capturePostHogEvent } from "../data/analytics";

  function initResumeTracking() {
    const link = document.querySelector<HTMLAnchorElement>('a[data-track-event="resume-download"]');
    if (!link || link.dataset.analyticsBound === "1") return;
    link.dataset.analyticsBound = "1";

    link.addEventListener("click", () => {
      capturePostHogEvent(POSTHOG_EVENTS.RESUME_CLICK, {
        location: "hero",
      });
    });
  }

  initResumeTracking();
  document.addEventListener("astro:page-load", initResumeTracking);
</script>

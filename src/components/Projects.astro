---
import SectionHeader from "./SectionHeader.astro";
import TechTag from "./TechTag.astro";
import { projects } from "../data/projects";

const featured = projects.filter((p) => p.featured);
const archived = projects.filter((p) => !p.featured);
---

<section class="py-16 sm:py-20 border-b border-rule reveal" id="projects" data-reveal="scale-up">
  <SectionHeader num="02" title="Selected Work" tagline="Things I've shipped, and things I'm proud of." />

  <div class="space-y-5">
    {featured.map((project, idx) => (
      <article
        style={`--project-delay: ${90 + idx * 80}ms;`}
        class="project-reveal project-card-hover group rounded-xl border border-rule bg-bg-card relative overflow-hidden"
      >
        <div class="flex flex-col md:flex-row">
          <div class="relative aspect-[16/10] md:aspect-auto md:w-[42%] shrink-0 border-b md:border-b-0 md:border-r border-rule bg-ink/[0.02] overflow-hidden rounded-t-xl md:rounded-t-none md:rounded-l-xl">
            {project.screenshot ? (
              <a
                href={project.demoUrl || project.githubUrl || "#"}
                target="_blank"
                rel="noopener noreferrer"
                data-project-name={project.name}
                data-link-type={project.demoUrl ? "demo" : "github"}
                data-track-event="project-link"
                class="block h-full"
              >
                <img
                  src={project.screenshot}
                  alt={`${project.name} screenshot`}
                  width="800"
                  height="500"
                  loading={idx === 0 ? "eager" : "lazy"}
                  class="w-full h-full object-contain transition-transform duration-600 ease-smooth group-hover:scale-[1.02]"
                />
              </a>
            ) : (
              <a
                href={project.demoUrl || project.githubUrl || "#"}
                target="_blank"
                rel="noopener noreferrer"
                data-project-name={project.name}
                data-link-type={project.demoUrl ? "demo" : "github"}
                data-track-event="project-link"
                class="flex items-center justify-center h-full min-h-[200px] md:min-h-0"
              >
                <span class="font-display text-[clamp(5rem,12vw,9rem)] font-bold leading-none text-ink/[0.04] select-none transition-transform duration-600 ease-smooth group-hover:scale-105 group-hover:text-accent/[0.08]">
                  {project.name.charAt(0)}
                </span>
              </a>
            )}
          </div>

          <div class="flex-1 p-5 sm:p-7 flex flex-col justify-between">
            <div>
              <span class="font-ui text-xs text-ink-muted mb-3 block">
                {project.year}
              </span>

              <h3 class="font-display text-xl sm:text-2xl md:text-[1.75rem] font-bold tracking-[-0.01em] mb-3 leading-tight">
                {project.name}
              </h3>

              <p class="text-[15px] leading-[1.75] text-ink-soft mb-5 max-w-xl">
                {project.intro}
              </p>

              <div class="flex flex-wrap gap-2 mb-6">
                {project.techStack.map((tech) => (
                  <TechTag tech={tech} />
                ))}
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-2.5">
              {project.githubUrl && (
                <a
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-project-name={project.name}
                  data-link-type="github"
                  data-track-event="project-link"
                  class="inline-flex items-center gap-2 px-4 py-2 border border-rule rounded-lg font-ui text-xs text-ink transition-all duration-250 ease-smooth hover:border-accent hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor" aria-hidden="true">
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                  </svg>
                  Source
                </a>
              )}
              {project.demoUrl && (
                <a
                  href={project.demoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-project-name={project.name}
                  data-link-type="demo"
                  data-track-event="project-link"
                  class="inline-flex items-center gap-2 px-4 py-2 bg-accent text-white rounded-lg font-ui text-xs transition-all duration-250 ease-smooth hover:shadow-[0_4px_16px_oklch(48%_0.10_150_/_0.25)] hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  Live
                  <svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 12L12 4M12 4H5M12 4v7" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>

  {archived.length > 0 && (
    <details class="archive-section mt-10 group/archive">
      <summary
        class="flex items-center gap-4 cursor-pointer select-none py-3.5 px-5 list-none [&::-webkit-details-marker]:hidden rounded-lg border border-dashed border-rule hover:border-ink/30 transition-all duration-300 ease-smooth"
      >
        <span class="font-ui text-sm text-ink-muted group-hover/archive:text-accent transition-colors duration-250">
          +{archived.length} more from the archive
        </span>
        <span class="flex-1 h-px bg-rule"></span>
        <span class="archive-chevron text-ink-muted group-hover/archive:text-accent transition-all duration-300 ease-smooth">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 6l4 4 4-4" />
          </svg>
        </span>
      </summary>

      <div class="archive-content pt-2 pb-2">
        {archived.map((project, idx) => (
          <div
            class:list={[
              "archive-row py-4 sm:py-5 flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-5",
              idx < archived.length - 1 && "border-b border-rule",
            ]}
          >
            <div class="sm:w-[220px] shrink-0">
              <h4 class="font-display text-sm font-bold leading-tight">
                {project.name}
              </h4>
              <span class="font-ui text-xs text-ink-muted mt-1 block">
                {project.year}
              </span>
            </div>

            <p class="text-sm text-ink-soft leading-[1.7] flex-1 min-w-0">
              {project.intro}
            </p>

            <div class="flex flex-col gap-1.5 sm:shrink-0 sm:items-end">
              <div class="flex flex-wrap gap-1.5 sm:justify-end">
                {project.techStack.map((tech) => (
                  <TechTag tech={tech} size="sm" />
                ))}
              </div>
              <div class="flex items-center gap-3">
                {project.githubUrl && (
                  <a
                    href={project.githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-project-name={project.name}
                    data-link-type="github"
                    data-track-event="project-link"
                    class="inline-flex items-center gap-1.5 font-ui text-xs text-ink-soft hover:text-accent transition-colors duration-250"
                  >
                    <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor" aria-hidden="true">
                      <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                    </svg>
                    Code
                  </a>
                )}
                {project.demoUrl && (
                  <a
                    href={project.demoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-project-name={project.name}
                    data-link-type="demo"
                    data-track-event="project-link"
                    class="inline-flex items-center gap-1.5 font-ui text-xs text-ink-soft hover:text-accent transition-colors duration-250"
                  >
                    Demo
                    <svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M4 12L12 4M12 4H5M12 4v7" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </details>
  )}
</section>

<script>
  import { POSTHOG_EVENTS, capturePostHogEvent } from "../data/analytics";

  function initProjectLinkTracking() {
    document
      .querySelectorAll<HTMLAnchorElement>('a[data-track-event="project-link"]')
      .forEach((link) => {
        if (link.dataset.analyticsBound === "1") return;
        link.dataset.analyticsBound = "1";

        link.addEventListener("click", () => {
          const projectName = link.dataset.projectName;
          const linkType = link.dataset.linkType;
          if (!projectName || !linkType) return;
          capturePostHogEvent(POSTHOG_EVENTS.PROJECT_LINK_CLICK, {
            project_name: projectName,
            link_type: linkType,
          });
        });
      });
  }

  function initArchiveToggleLabel() {
    document.querySelectorAll<HTMLDetailsElement>(".archive-section").forEach((details) => {
      if (details.dataset.toggleBound) return;
      details.dataset.toggleBound = "1";

      details.addEventListener("toggle", () => {
        if (details.open) {
          capturePostHogEvent(POSTHOG_EVENTS.ARCHIVE_EXPAND, {
            section: "projects_archive",
          });
        }
      });
    });
  }

  initProjectLinkTracking();
  initArchiveToggleLabel();
  document.addEventListener("astro:page-load", initProjectLinkTracking);
  document.addEventListener("astro:page-load", initArchiveToggleLabel);
</script>

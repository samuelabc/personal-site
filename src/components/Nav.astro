---
const links = [
  { label: "Work", href: "/#projects" },
  { label: "Experience", href: "/#experience" },
  { label: "Research", href: "/#publication" },
  { label: "Bookshelf", href: "/bookshelf" },
  { label: "Say Hi", href: "/#contact" },
];
---

<nav
  class="sticky top-0 z-50 flex items-center justify-between border-b-3 border-ink bg-bg px-4 sm:px-10 py-3 sm:py-4 gap-2"
>
  <a href="/" data-cursor-label="Home" class="font-display text-sm sm:text-lg uppercase tracking-[0.05em] no-underline text-inherit shrink-0">
    Samuel Thien<span class="status-dot ml-0.5 inline-block h-2 w-2 rounded-full bg-accent"></span>
  </a>

  {/* Desktop nav links */}
  <div class="hidden sm:flex gap-2">
    {
      links.map((link) => (
        <a
          href={link.href}
          data-cursor-label="Jump"
          class="font-mono text-[11px] uppercase tracking-[0.1em] text-ink-muted px-3 py-1.5 border border-transparent transition-[color,border-color] duration-250 ease-smooth hover:text-ink hover:border-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          {link.label}
        </a>
      ))
    }
  </div>

  {/* Mobile hamburger button */}
  <button
    id="mobile-menu-toggle"
    class="sm:hidden relative z-[70] w-10 h-10 flex items-center justify-center"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <div class="mobile-burger" aria-hidden="true">
      <span class="mobile-burger__line mobile-burger__line--1"></span>
      <span class="mobile-burger__line mobile-burger__line--2"></span>
      <span class="mobile-burger__line mobile-burger__line--3"></span>
    </div>
  </button>
</nav>

{/* Mobile full-screen menu */}
<div
  id="mobile-menu"
  class="mobile-menu"
  aria-hidden="true"
>
  <div class="mobile-menu__inner">
    <div class="mobile-menu__top">
      <span class="mobile-menu__eyebrow">Navigation</span>
      <button
        id="mobile-menu-close"
        type="button"
        class="mobile-menu__close"
        aria-label="Close menu"
      >
        <span class="mobile-menu__close-text">Close</span>
        <span class="mobile-menu__close-x" aria-hidden="true">&times;</span>
      </button>
    </div>
    <nav class="mobile-menu__nav">
      {
        links.map((link, i) => (
          <a
            href={link.href}
            class="mobile-menu__link"
            style={`--link-index: ${i}`}
          >
            <span class="mobile-menu__link-label">{link.label}</span>
            <span class="mobile-menu__link-arrow" aria-hidden="true">&#8594;</span>
          </a>
        ))
      }
    </nav>
    <div class="mobile-menu__footer">
      <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-ink-muted">
        Full Stack Engineer &middot; KL, Malaysia
      </span>
    </div>
  </div>
</div>

<script>
  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    const btn = toggle;
    const panel = menu;
    if (btn.dataset.menuBound === '1') return;
    btn.dataset.menuBound = '1';
    const burger = btn.querySelector('.mobile-burger');
    const closeButton = panel.querySelector('#mobile-menu-close');

    function openMenu() {
      panel.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', 'Close menu');
      panel.setAttribute('aria-hidden', 'false');
      burger?.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      panel.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      panel.setAttribute('aria-hidden', 'true');
      burger?.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', () => {
      const isOpen = panel.classList.contains('is-open');
      if (isOpen) closeMenu();
      else openMenu();
    });

    panel.querySelectorAll('.mobile-menu__link').forEach((link) => {
      link.addEventListener('click', () => closeMenu());
    });

    closeButton?.addEventListener('click', () => {
      closeMenu();
      btn.focus();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.classList.contains('is-open')) {
        closeMenu();
        btn.focus();
      }
    });
  }

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>

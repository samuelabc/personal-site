---
const links = [
  { label: "Work", href: "/#projects" },
  { label: "Talks", href: "/#talks" },
  { label: "Experience", href: "/#experience" },
  { label: "Bookshelf", href: "/bookshelf" },
  { label: "Say Hi", href: "/#contact" },
];
---

<nav
  class="sticky top-0 z-50 flex items-center justify-between border-b border-rule bg-bg/95 backdrop-blur-sm px-4 sm:px-10 py-3 sm:py-4 gap-2"
>
  <a href="/" class="font-display text-base sm:text-lg font-bold tracking-[-0.01em] no-underline text-inherit shrink-0">
    Samuel Thien
  </a>

  <div class="hidden sm:flex gap-1">
    {
      links.map((link) => (
        <a
          href={link.href}
          data-track-event="nav-click"
          data-nav-label={link.label}
          data-nav-device="desktop"
          class="font-ui text-[13px] text-ink-muted px-3 py-1.5 rounded-md transition-colors duration-250 ease-smooth hover:text-ink hover:bg-ink/[0.04] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          {link.label}
        </a>
      ))
    }
  </div>

  <button
    id="mobile-menu-toggle"
    class="sm:hidden relative z-[70] w-10 h-10 flex items-center justify-center"
    aria-label="Open menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <div class="mobile-burger" aria-hidden="true">
      <span class="mobile-burger__line mobile-burger__line--1"></span>
      <span class="mobile-burger__line mobile-burger__line--2"></span>
      <span class="mobile-burger__line mobile-burger__line--3"></span>
    </div>
  </button>
</nav>

<div
  id="mobile-menu"
  class="mobile-menu"
  aria-hidden="true"
>
  <div class="mobile-menu__inner">
    <div class="mobile-menu__top">
      <span class="mobile-menu__eyebrow">Navigation</span>
      <button
        id="mobile-menu-close"
        type="button"
        class="mobile-menu__close"
        aria-label="Close menu"
      >
        <span class="mobile-menu__close-text">Close</span>
        <span class="mobile-menu__close-x" aria-hidden="true">&times;</span>
      </button>
    </div>
    <nav class="mobile-menu__nav">
      {
        links.map((link, i) => (
          <a
            href={link.href}
            data-track-event="nav-click"
            data-nav-label={link.label}
            data-nav-device="mobile"
            class="mobile-menu__link"
            style={`--link-index: ${i}`}
          >
            <span class="mobile-menu__link-label">{link.label}</span>
            <span class="mobile-menu__link-arrow" aria-hidden="true">&#8594;</span>
          </a>
        ))
      }
    </nav>
    <div class="mobile-menu__footer">
      <span class="font-ui text-xs text-ink-muted">
        Full Stack Engineer &middot; KL, Malaysia
      </span>
    </div>
  </div>
</div>

<script>
  import { POSTHOG_EVENTS, capturePostHogEvent } from "../data/analytics";

  function initNavTracking() {
    document
      .querySelectorAll<HTMLAnchorElement>('a[data-track-event="nav-click"]')
      .forEach((link) => {
        if (link.dataset.analyticsBound === "1") return;
        link.dataset.analyticsBound = "1";

        link.addEventListener("click", () => {
          const label = link.dataset.navLabel;
          const device = link.dataset.navDevice;
          if (!label || !device) return;

          capturePostHogEvent(POSTHOG_EVENTS.NAV_CLICK, {
            label,
            device,
          });
        });
      });
  }

  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    const btn = toggle;
    const panel = menu;
    if (btn.dataset.menuBound === '1') return;
    btn.dataset.menuBound = '1';
    const burger = btn.querySelector('.mobile-burger');
    const closeButton = panel.querySelector('#mobile-menu-close');

    function openMenu() {
      panel.classList.add('is-open');
      btn.setAttribute('aria-expanded', 'true');
      btn.setAttribute('aria-label', 'Close menu');
      panel.setAttribute('aria-hidden', 'false');
      burger?.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      panel.classList.remove('is-open');
      btn.setAttribute('aria-expanded', 'false');
      btn.setAttribute('aria-label', 'Open menu');
      panel.setAttribute('aria-hidden', 'true');
      burger?.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', () => {
      const isOpen = panel.classList.contains('is-open');
      if (isOpen) closeMenu();
      else openMenu();
    });

    panel.querySelectorAll('.mobile-menu__link').forEach((link) => {
      link.addEventListener('click', () => closeMenu());
    });

    closeButton?.addEventListener('click', () => {
      closeMenu();
      btn.focus();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.classList.contains('is-open')) {
        closeMenu();
        btn.focus();
      }
    });
  }

  initNavTracking();
  initMobileMenu();
  document.addEventListener('astro:page-load', initNavTracking);
  document.addEventListener('astro:page-load', initMobileMenu);
</script>

<section class="py-20 sm:py-28 pb-24 sm:pb-32 text-center reveal" id="contact" data-reveal="center-fade">
  <h3 class="font-display text-[clamp(2.5rem,9vw,72px)] uppercase leading-[0.92] mb-2 contact-heading">
    Let's build
  </h3>
  <span class="font-serif text-[clamp(2rem,7vw,3.5rem)] italic font-normal text-accent block mb-7 contact-serif">
    <span class="contact-word inline-block">something&nbsp;</span><span class="contact-word inline-block">together.</span>
  </span>
  <p class="text-[15px] text-ink-soft mb-10 max-w-[380px] mx-auto leading-relaxed">
    Got a project, a question, or a terrible pun? I'm all ears. Don't be a
    stranger.
  </p>
  <a
    href="mailto:samuelthien@yahoo.com"
    data-cursor-label="Contact"
    data-track-event="contact-click"
    class="pressable pressable-strong group inline-flex items-center gap-2.5 px-10 sm:px-12 py-4.5 bg-accent text-white font-mono text-[13px] uppercase tracking-[0.12em] border-3 border-ink transition-[background-color,transform,box-shadow] duration-300 ease-smooth hover:bg-ink hover:-translate-y-0.5 hover:shadow-[6px_6px_0_var(--color-accent)] no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
  >
    Get in Touch
    <span
      class="transition-transform duration-300 ease-smooth group-hover:translate-x-1"
      >→</span
    >
  </a>
</section>

<script>
  import { POSTHOG_EVENTS, capturePostHogEvent } from "../data/analytics";

  function initContactTracking() {
    const link = document.querySelector<HTMLAnchorElement>('a[data-track-event="contact-click"]');
    if (!link || link.dataset.analyticsBound === "1") return;
    link.dataset.analyticsBound = "1";

    link.addEventListener("click", () => {
      capturePostHogEvent(POSTHOG_EVENTS.CONTACT_CLICK, {
        cta: "get_in_touch",
        location: "contact_section",
      });
    });
  }

  initContactTracking();
  document.addEventListener("astro:page-load", initContactTracking);
</script>

<section class="py-24 sm:py-32 text-center reveal" id="contact" data-reveal="center-fade">
  <h3 class="font-display text-[clamp(2.25rem,8vw,4.5rem)] font-bold leading-[1] mb-3">
    <span class="contact-word inline-block">Let's talk.</span>
  </h3>
  <p class="text-base sm:text-[17px] text-ink-soft mb-10 max-w-[400px] mx-auto leading-relaxed">
    Got something in mind, or just want to say hello? Drop me a line.
  </p>
  <a
    href="mailto:samuelthien@yahoo.com"
    data-track-event="contact-click"
    class="pressable group inline-flex items-center gap-2.5 px-10 sm:px-12 py-4 bg-accent text-white font-ui text-sm tracking-wide rounded-lg transition-[background-color,transform,box-shadow] duration-300 ease-smooth hover:shadow-[0_6px_24px_oklch(48%_0.10_150_/_0.25)] hover:-translate-y-0.5 no-underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
  >
    Say hello
    <span
      class="transition-transform duration-300 ease-smooth group-hover:translate-x-1"
      >&rarr;</span
    >
  </a>
  <p class="mt-6 text-sm text-ink-muted font-body">
    Or find me on
    <a
      href="https://github.com/samuelabc"
      target="_blank"
      rel="noopener noreferrer"
      data-track-event="external-link"
      data-external-url="https://github.com/samuelabc"
      data-external-label="GitHub"
      class="text-ink-soft no-underline transition-colors duration-250 hover:text-accent"
    >GitHub</a> and
    <a
      href="https://linkedin.com/in/samuel-thien-18b9071ab"
      target="_blank"
      rel="noopener noreferrer"
      data-track-event="external-link"
      data-external-url="https://linkedin.com/in/samuel-thien-18b9071ab"
      data-external-label="LinkedIn"
      class="text-ink-soft no-underline transition-colors duration-250 hover:text-accent"
    >LinkedIn</a>.
  </p>
</section>

<script>
  import { POSTHOG_EVENTS, capturePostHogEvent } from "../data/analytics";

  function initContactTracking() {
    const emailLink = document.querySelector<HTMLAnchorElement>('a[data-track-event="contact-click"]');
    if (emailLink && emailLink.dataset.analyticsBound !== "1") {
      emailLink.dataset.analyticsBound = "1";
      emailLink.addEventListener("click", () => {
        capturePostHogEvent(POSTHOG_EVENTS.CONTACT_CLICK, {
          cta: "say_hello",
          location: "contact_section",
        });
      });
    }

    document
      .querySelectorAll<HTMLAnchorElement>('#contact a[data-track-event="external-link"]')
      .forEach((link) => {
        if (link.dataset.analyticsBound === "1") return;
        link.dataset.analyticsBound = "1";
        link.addEventListener("click", () => {
          capturePostHogEvent(POSTHOG_EVENTS.EXTERNAL_LINK_CLICK, {
            url: link.dataset.externalUrl,
            label: link.dataset.externalLabel,
            location: "contact_section",
          });
        });
      });
  }

  initContactTracking();
  document.addEventListener("astro:page-load", initContactTracking);
</script>

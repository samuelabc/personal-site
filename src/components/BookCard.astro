---
interface Props {
  title: string;
  slug: string;
  author: string;
  cover?: string;
  rating: number;
  note: string;
  year: string;
  color?: string;
}

const { title, slug, author, cover, year, color = "#6b3a3a" } = Astro.props;
---

<a
  href={`/bookshelf/${slug}`}
  class="book-card"
  data-book-title={title}
  transition:name={`book-${slug}`}
>
  {
    cover ? (
      <img
        src={cover}
        alt={`Cover of ${title}`}
        class="book-card__cover"
        loading="lazy"
      />
    ) : (
      <div
        class="book-card__cover book-card__cover--typo"
        style={`background-color:${color}`}
      >
        <div class="absolute inset-[5px] border border-white/10 rounded-md pointer-events-none" />
        <div class="relative z-10">
          <div class="font-display text-white/90 text-sm sm:text-base leading-snug italic font-bold">
            {title}
          </div>
        </div>
        <div class="relative z-10">
          <div class="w-8 h-[1.5px] bg-white/20 mb-2 rounded-full" />
          <div class="font-ui text-[8px] sm:text-[9px] text-white/55 uppercase tracking-[0.08em]">
            {author}
          </div>
        </div>
      </div>
    )
  }
  <div class="book-card__year-badge" aria-hidden="true">
    Read in {year}
  </div>
  <div class="book-card__vignette" aria-hidden="true"></div>
</a>

<script>
  import { POSTHOG_EVENTS, capturePostHogEvent } from "../data/analytics";

  function initBookCards() {
    document
      .querySelectorAll<HTMLAnchorElement>("a.book-card[data-book-title]")
      .forEach((card) => {
        if (card.dataset.bookBound) return;
        card.dataset.bookBound = "1";

        card.addEventListener("click", () => {
          const title = card.dataset.bookTitle;
          if (title) {
            capturePostHogEvent(POSTHOG_EVENTS.BOOK_CLICK, {
              book_title: title,
            });
          }
        });
      });
  }

  initBookCards();
  document.addEventListener("astro:page-load", initBookCards);
</script>

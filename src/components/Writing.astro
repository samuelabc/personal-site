---
import SectionHeader from "./SectionHeader.astro";
---

<section class="py-16 border-b-3 border-ink reveal" id="publication">
  <SectionHeader num="04" title="Publication" />

  <div class="flex flex-col gap-1.5">
    <a
      href="https://ieeexplore.ieee.org/document/9874139"
      target="_blank"
      rel="noopener noreferrer"
      class="group flex justify-between items-center border-3 border-ink px-7 py-5.5 bg-bg-card transition-all duration-300 ease-smooth hover:translate-x-1.5 hover:border-accent no-underline text-inherit"
    >
      <div class="flex items-baseline gap-4">
        <span class="font-mono text-[11px] text-ink-muted min-w-[72px]">
          Sep 2022
        </span>
        <div>
          <span class="font-serif text-[22px] font-normal italic block">
            RegWeight: Adversarial Training based on Dynamically-Adjusted Regularization Weights
          </span>
          <span class="font-mono text-[11px] text-ink-muted mt-1 block">
            IEEE — International Joint Conference on Neural Networks (IJCNN)
          </span>
        </div>
      </div>
      <span class="text-xl text-ink-muted transition-all duration-300 ease-smooth group-hover:translate-x-1.5 group-hover:text-accent shrink-0 ml-4">
        →
      </span>
    </a>
  </div>
</section>

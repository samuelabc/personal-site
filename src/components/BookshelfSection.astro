---
import SectionHeader from "./SectionHeader.astro";
import BookCard from "./BookCard.astro";

interface Book {
  title: string;
  slug: string;
  author: string;
  cover?: string;
  rating: number;
  note: string;
  year: string;
  color?: string;
}

interface Props {
  num: string;
  title: string;
  books: Book[];
}

const { num, title, books } = Astro.props;
---

<section class="py-10 sm:py-14">
  <SectionHeader num={num} title={title} />

  <div class="bookshelf-grid">
    {
      books.map((book, i) => (
        <div class="reveal" style={`transition-delay:${i * 120}ms`}>
          <BookCard {...book} />
        </div>
      ))
    }
  </div>

  <div class="shelf-edge" aria-hidden="true"></div>
</section>

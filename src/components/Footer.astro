---
const socialLinks = [
  { label: "GitHub", href: "https://github.com/samuelabc" },
  { label: "LinkedIn", href: "https://linkedin.com/in/samuel-thien-18b9071ab" },
];
---

<footer
  class="border-t-3 border-ink px-10 py-5 flex justify-between items-center font-mono text-[11px] text-ink-muted tracking-[0.05em]"
>
  <span>&copy; 2026 Samuel Thien</span>
  <div class="flex gap-5">
    {
      socialLinks.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="uppercase text-ink-muted no-underline transition-colors duration-200 hover:text-accent"
        >
          {link.label}
        </a>
      ))
    }
  </div>
  <span>Built with Astro + Tailwind</span>
</footer>

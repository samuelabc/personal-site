---
const siteLinks = [
  { label: "Work", href: "/#projects" },
  { label: "Experience", href: "/#experience" },
  { label: "Research", href: "/#publication" },
  { label: "Bookshelf", href: "/bookshelf" },
  { label: "Contact", href: "/#contact" },
];

const socialLinks = [
  { label: "GitHub", href: "https://github.com/samuelabc" },
  { label: "LinkedIn", href: "https://linkedin.com/in/samuel-thien-18b9071ab" },
];
---

<footer class="border-t-3 border-ink px-5 sm:px-10 py-6 font-mono text-[11px] text-ink-muted tracking-[0.05em]">
  <div class="flex flex-wrap justify-center gap-x-5 gap-y-1 mb-4">
    {
      siteLinks.map((link) => (
        <a
          href={link.href}
          data-cursor-label="Jump"
          data-footer-link-label={link.label}
          class="uppercase text-ink-muted no-underline transition-colors duration-200 hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          {link.label}
        </a>
      ))
    }
  </div>
  <div class="flex flex-col sm:flex-row gap-3 sm:gap-0 sm:justify-between items-center">
    <span>&copy; 2026 Samuel Thien</span>
    <div class="flex gap-5">
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            data-cursor-label="Open"
            data-track-event="external-link"
            data-external-url={link.href}
            data-external-label={link.label}
            class="uppercase text-ink-muted no-underline transition-colors duration-200 hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            {link.label}
          </a>
        ))
      }
    </div>
    <span>Built with Astro + curiosity</span>
  </div>
</footer>

<script>
  import { POSTHOG_EVENTS, capturePostHogEvent } from "../data/analytics";

  function initFooterExternalTracking() {
    document
      .querySelectorAll<HTMLAnchorElement>('a[data-track-event="external-link"]')
      .forEach((link) => {
        if (link.dataset.analyticsBound === "1") return;
        link.dataset.analyticsBound = "1";

        link.addEventListener("click", () => {
          const url = link.dataset.externalUrl;
          const label = link.dataset.externalLabel;
          if (!url || !label) return;

          capturePostHogEvent(POSTHOG_EVENTS.EXTERNAL_LINK_CLICK, {
            url,
            label,
            location: "footer",
          });
        });
      });
  }

  initFooterExternalTracking();
  document.addEventListener("astro:page-load", initFooterExternalTracking);
</script>

---
interface Props {
  num: string;
  title: string;
  tagline?: string;
}

const { num, title, tagline } = Astro.props;
---

<div class="mb-8 sm:mb-10">
  <div class="flex items-center gap-3">
    <span class="font-ui text-xs text-accent font-medium">{num}</span>
    <div class="font-display text-lg sm:text-xl font-bold tracking-[-0.01em]">
      {title}
    </div>
  </div>
  {tagline && (
    <p class="mt-2 ml-[28px] text-[15px] text-ink-soft leading-snug">
      {tagline}
    </p>
  )}
</div>

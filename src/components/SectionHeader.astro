---
interface Props {
  num: string;
  title: string;
  tagline?: string;
}

const { num, title, tagline } = Astro.props;
---

<div class="mb-6 sm:mb-8">
  <div class="flex items-center gap-4 sm:gap-5">
    <div
      class="font-mono text-[11px] sm:text-xs bg-ink text-bg w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center shrink-0 font-bold"
    >
      {num}
    </div>
    <div class="font-display text-sm sm:text-base uppercase tracking-[0.12em]">
      {title}
    </div>
  </div>
  {tagline && (
    <p class="mt-2 ml-[52px] sm:ml-[60px] font-serif italic text-[15px] sm:text-base text-ink-soft leading-snug">
      {tagline}
    </p>
  )}
</div>

---
import Base from "./Base.astro";

interface Props {
  title: string;
  subtitle: string;
  date: Date;
  tags: string[];
  readTime: string;
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { title, subtitle, date, tags, readTime, headings } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const showToc = tocHeadings.length >= 2;
---

<Base
  title={`${title} — Samuel Thien`}
  description={subtitle}
  canonicalPath={Astro.url.pathname}
  ogType="article"
>
  <article class="py-12 sm:py-16" id="blog-article">
    <header class="mb-10 sm:mb-14 max-w-[720px] mx-auto">
      <a
        href="/writing"
        class="inline-flex items-center gap-1.5 font-ui text-xs text-ink-muted no-underline hover:text-accent transition-colors duration-250 mb-6 group py-2 -my-2"
      >
        <span class="transition-transform duration-250 group-hover:-translate-x-0.5">&larr;</span>
        Writing
      </a>

      <h1 class="font-display text-[1.75rem] sm:text-[2.25rem] font-bold leading-[1.15] tracking-[-0.015em] mb-3">
        {title}
      </h1>
      <p class="text-[17px] sm:text-lg text-ink-soft leading-snug italic">
        {subtitle}
      </p>

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-5 font-ui text-xs text-ink-muted">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span>&middot;</span>
        <span>{readTime} read</span>
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-4">
          {tags.map((tag) => (
            <span class="font-ui text-[11px] text-ink-muted bg-ink/[0.04] px-2 py-0.5 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {showToc && (
      <details class="toc-mobile" id="toc-mobile">
        <summary class="toc-mobile__summary">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="toc-mobile__icon">
            <path d="M2.5 4h11M2.5 8h7M2.5 12h9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          On this page
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="toc-mobile__chevron">
            <path d="M3 4.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <nav class="toc-mobile__nav" aria-label="Table of contents">
          <ul class="toc-list">
            {tocHeadings.map((h) => (
              <li class={h.depth === 3 ? "toc-item toc-item--sub" : "toc-item"}>
                <a href={`#${h.slug}`} class="toc-link" data-toc-id={h.slug}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </details>
    )}

    <div class="prose">
      <slot />
    </div>
  </article>

  {showToc && (
    <button class="back-to-top" id="back-to-top" aria-label="Back to top">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M7 12V2M7 2L2.5 6.5M7 2L11.5 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Top
    </button>
  )}

  {showToc && (
    <aside class="toc-desktop" id="toc-desktop" aria-label="Table of contents">
      <p class="toc-desktop__title">On this page</p>
      <nav>
        <ul class="toc-list">
          {tocHeadings.map((h) => (
            <li class={h.depth === 3 ? "toc-item toc-item--sub" : "toc-item"}>
              <a href={`#${h.slug}`} class="toc-link" data-toc-id={h.slug}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )}

  <script is:inline>
    (function() {
      function wrapTables() {
        document.querySelectorAll('.prose table').forEach(function(table) {
          if (table.parentElement.classList.contains('table-wrapper')) return;
          var wrapper = document.createElement('div');
          wrapper.className = 'table-wrapper';
          table.parentNode.insertBefore(wrapper, table);
          wrapper.appendChild(table);
        });
        document.querySelectorAll('.prose .table-wrapper').forEach(function(wrapper) {
          function checkScroll() {
            var atEnd = wrapper.scrollLeft + wrapper.clientWidth >= wrapper.scrollWidth - 2;
            wrapper.classList.toggle('scrolled-end', atEnd);
            var noOverflow = wrapper.scrollWidth <= wrapper.clientWidth;
            wrapper.classList.toggle('scrolled-end', atEnd || noOverflow);
          }
          wrapper.addEventListener('scroll', checkScroll, { passive: true });
          checkScroll();
        });
      }

      function resolveColor(cssColor) {
        var cv = document.createElement('canvas');
        cv.width = cv.height = 1;
        var cx = cv.getContext('2d');
        cx.fillStyle = cssColor;
        cx.fillRect(0, 0, 1, 1);
        var d = cx.getImageData(0, 0, 1, 1).data;
        return d[3] < 255
          ? 'rgba(' + d[0] + ',' + d[1] + ',' + d[2] + ',' + (d[3] / 255).toFixed(2) + ')'
          : '#' + Array.from(d).slice(0, 3).map(function(c) { return c.toString(16).padStart(2, '0'); }).join('');
      }

      async function initMermaid() {
        var mermaidDivs = document.querySelectorAll('.mermaid');
        if (mermaidDivs.length === 0) return;

        var mod = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
        var mermaid = mod.default;
        mermaid.initialize({
          startOnLoad: false,
          theme: 'base',
          themeVariables: {
            primaryColor: resolveColor('oklch(96% 0.02 150)'),
            primaryTextColor: resolveColor('oklch(22% 0.015 160)'),
            primaryBorderColor: resolveColor('oklch(48% 0.10 150)'),
            lineColor: resolveColor('oklch(48% 0.10 150)'),
            secondaryColor: resolveColor('oklch(72% 0.08 230 / 0.15)'),
            tertiaryColor: resolveColor('oklch(78% 0.13 85 / 0.15)'),
            clusterBkg: resolveColor('oklch(96% 0.01 150 / 0.4)'),
            clusterBorder: resolveColor('oklch(48% 0.10 150 / 0.4)'),
            titleColor: resolveColor('oklch(22% 0.015 160)'),
            fontFamily: '"Libre Franklin", sans-serif',
            fontSize: window.innerWidth < 640 ? '16px' : '14px',
          },
        });
        await mermaid.run({ nodes: mermaidDivs });
      }

      var tocObserver = null;
      var scrollHandler = null;

      function initToc() {
        if (tocObserver) tocObserver.disconnect();
        if (scrollHandler) window.removeEventListener('scroll', scrollHandler);

        var headings = document.querySelectorAll('.prose h2[id], .prose h3[id]');
        var tocLinks = document.querySelectorAll('.toc-link[data-toc-id]');
        var desktopToc = document.getElementById('toc-desktop');
        var backToTop = document.getElementById('back-to-top');
        var mobileToc = document.getElementById('toc-mobile');
        var article = document.getElementById('blog-article');

        if (headings.length === 0 || tocLinks.length === 0) return;

        var activeId = null;
        var ticking = false;

        function setActive(id) {
          if (id === activeId) return;
          activeId = id;
          tocLinks.forEach(function(link) {
            var isActive = link.getAttribute('data-toc-id') === id;
            link.classList.toggle('is-active', isActive);
          });
        }

        function onScroll() {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(function() {
            ticking = false;
            var scrollY = window.scrollY + 100;
            var best = null;
            headings.forEach(function(h) {
              if (h.offsetTop <= scrollY) best = h.id;
            });
            if (best) setActive(best);

            if (desktopToc) {
              var prose = document.querySelector('.prose');
              if (prose) {
                var proseRect = prose.getBoundingClientRect();
                var tocRect = desktopToc.getBoundingClientRect();
                var shouldShow = proseRect.top < window.innerHeight && proseRect.bottom > tocRect.bottom;
                desktopToc.classList.toggle('is-visible', shouldShow);
              }
            }

            if (backToTop && mobileToc) {
              var tocBottom = mobileToc.getBoundingClientRect().bottom;
              backToTop.classList.toggle('is-visible', tocBottom < 0);
            }
          });
        }

        scrollHandler = onScroll;

        if (backToTop) {
          backToTop.addEventListener('click', function() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
        window.addEventListener('scroll', scrollHandler, { passive: true });
        onScroll();

        tocLinks.forEach(function(link) {
          link.addEventListener('click', function(e) {
            var mobileDetails = document.getElementById('toc-mobile');
            if (mobileDetails && mobileDetails.open) {
              mobileDetails.open = false;
            }
          });
        });
      }

      function init() {
        wrapTables();
        initMermaid();
        initToc();
      }

      init();
      document.addEventListener('astro:page-load', init);
    })();
  </script>
</Base>
